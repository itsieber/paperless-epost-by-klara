# ══════════════════════════════════════════════════════════════════════════════
# .env.example — Vorlage für alle Umgebungsvariablen
# Kopiere diese Datei zu .env und fülle alle Werte aus.
# WICHTIG: .env niemals ins Git committen!
# ══════════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_PUBLIC_IP=185.226.241.155
BASE_DOMAIN=itsieber.ch

# ── Nextcloud ─────────────────────────────────────────────────────────────────
NEXTCLOUD_TRUSTED_DOMAINS=nextcloud.itsieber.ch
NEXTCLOUD_MYSQL_ROOT_PASSWORD=
NEXTCLOUD_MYSQL_PASSWORD=

# ── Roundcube ─────────────────────────────────────────────────────────────────
MAIL_HOST=mail.itsieber.ch
ROUNDCUBE_MYSQL_ROOT_PASSWORD=
ROUNDCUBE_MYSQL_PASSWORD=

# ── OnlyOffice ────────────────────────────────────────────────────────────────
ONLYOFFICE_JWT_SECRET=

# ── AppAPI DSP ────────────────────────────────────────────────────────────────
DSP_HAPROXY_PASSWORD=

# ── TURN / Coturn ─────────────────────────────────────────────────────────────
TURN_DOMAIN=turn.itsieber.ch
TURN_SECRET=
CERTBOT_EMAIL=admin@itsieber.ch

# ── Paperless-ngx ─────────────────────────────────────────────────────────────
PAPERLESS_URL=https://paperless.itsieber.ch
PAPERLESS_SECRET_KEY=                        # langer Zufallsstring: openssl rand -hex 32
PAPERLESS_DB_PASSWORD=
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=

# ── E-Post Fetcher ────────────────────────────────────────────────────────────
EPOST_FETCH_INTERVAL=900                     # Sekunden zwischen den Abfragen (900 = 15 Min)
EPOST_DELETE_AFTER=true                      # Briefe nach Import auf E-Post löschen
EPOST_SAVE_METADATA=true                     # Metadata als JSON-Sidecar für Paperless speichern
EPOST_LETTER_FOLDERS=INBOX_FOLDER            # Komma-separierte Liste: INBOX_FOLDER,ARCHIVE_FOLDER

# Accounts als JSON-Array — Name wird als Unterordner im Consume-Verzeichnis verwendet:
# [{"key":"API_KEY_1","name":"firma-a"},{"key":"API_KEY_2","name":"firma-b"}]
EPOST_ACCOUNTS=[]
